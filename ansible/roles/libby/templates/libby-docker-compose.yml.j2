services:
  postgres:
    image: pgvector/pgvector:pg16
    container_name: libby-postgres
    environment:
      - POSTGRES_DB=${POSTGRES_DB:-libby}
      - POSTGRES_USER=${POSTGRES_USER:-libby}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - postgres-backups:/backups
      - ./docker/init-db.sql:/docker-entrypoint-initdb.d/01-init-pgvector.sql:ro
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-libby} -d ${POSTGRES_DB:-libby} && psql -U ${POSTGRES_USER:-libby} -d ${POSTGRES_DB:-libby} -c \"SELECT 1 FROM pg_extension WHERE extname='vector'\" | grep -q 1"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 60s
    restart: unless-stopped
    networks:
      - kwar-ai-network

  libby-api:
    build: https://github.com/your-org/libby.git#main
    image: libby-api:latest
    container_name: libby-api
    depends_on:
      postgres:
        condition: service_healthy
    ports:
      - "8000:8000"
    volumes:
      - libby-data:/data
      - ollama-models:/root/.ollama
      - ./data:/data/documents:ro
    environment:
      - EMBED_DB=postgresql://${POSTGRES_USER:-libby}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB:-libby}
      - COLLECTION_NAME=main
      - OLLAMA_HOST=http://localhost:11434
      - EMBEDDING_MODEL=${EMBEDDING_MODEL:-mxbai-embed-large}
      - GEMINI_API_KEY=${GEMINI_API_KEY:-}
      - OPENAI_API_KEY=${OPENAI_API_KEY:-}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    networks:
      - kwar-ai-network

  postgres-backup:
    image: pgvector/pgvector:pg16
    container_name: libby-postgres-backup
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      - POSTGRES_DB=${POSTGRES_DB:-libby}
      - POSTGRES_USER=${POSTGRES_USER:-libby}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      - POSTGRES_HOST=postgres
      - BACKUP_RETENTION_DAYS=${BACKUP_RETENTION_DAYS:-7}
      - BACKUP_SCHEDULE=${BACKUP_SCHEDULE:-0 2 * * *}
    volumes:
      - postgres-backups:/backups
    entrypoint: ["/bin/sh", "-c", "while true; do pg_dump -h $$POSTGRES_HOST -U $$POSTGRES_USER $$POSTGRES_DB | gzip > /backups/backup_$(date +%Y%m%d_%H%M%S).sql.gz && find /backups -name '*.sql.gz' -mtime +$$BACKUP_RETENTION_DAYS -delete && sleep 86400; done"]
    restart: unless-stopped
    networks:
      - kwar-ai-network

networks:
  kwar-ai-network:
    external: true

volumes:
  postgres-data:
    driver: local
  postgres-backups:
    driver: local
  libby-data:
    driver: local
  ollama-models:
    driver: local
