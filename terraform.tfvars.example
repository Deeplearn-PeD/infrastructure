# ============================================
# Hetzner Cloud Configuration
# ============================================

# Generate API token at: https://console.hetzner.cloud/projects/YOUR_PROJECT_ID/security/tokens
# Required permissions: Read & Write
hcloud_token = "YOUR_HETZNER_API_TOKEN_HERE"

# ============================================
# Server Configuration
# ============================================

server_name = "kwar-ai-server"
server_type = "cx43"  # 8 vCPU, 16GB RAM
location    = "hel1"  # Helsinki data center
image       = "ubuntu-24.04"

# SERVER TYPE OPTIONS (see SCALING.md for full list):
#
# Shared vCPU (Best Value):
#   cx23  - 2 vCPU,  4 GB RAM   - 4 EUR/mo  (dev/test)
#   cpx21 - 3 vCPU,  4 GB RAM   - 9 EUR/mo  (small workloads)
#   cpx31 - 4 vCPU,  8 GB RAM   - 15 EUR/mo (light production)
#   cx43  - 8 vCPU, 16 GB RAM   - 17 EUR/mo (recommended)
#   cpx51 - 16 vCPU, 32 GB RAM  - 54 EUR/mo (scale-up)
#
# Dedicated vCPU (Consistent Performance):
#   ccx23 - 4 vCPU, 16 GB RAM   - 30 EUR/mo (production)
#   ccx33 - 8 vCPU, 32 GB RAM   - 60 EUR/mo (high-traffic)
#   ccx43 - 16 vCPU, 64 GB RAM  - 120 EUR/mo (large-scale)

# LOCATION OPTIONS:
#   hel1 - Helsinki, Finland (EU) - 20TB free traffic [RECOMMENDED]
#   nbg1 - Nuremberg, Germany (EU) - 20TB free traffic
#   fsn1 - Falkenstein, Germany (EU) - 20TB free traffic
#   ash  - Ashburn, VA, USA - 1TB free traffic
#   hil  - Hillsboro, OR, USA - 1TB free traffic
#   sin  - Singapore (APAC) - 0.5TB free traffic

# ============================================
# Volume Configuration (Optional Overrides)
# ============================================
# Default sizes are set in modules/volumes/variables.tf
# Uncomment and modify these to scale storage:

# postgres_volume_size     = 50   # GB - PostgreSQL data (default: 50)
# libby_volume_size        = 20   # GB - Ollama models + embeddings (default: 20)
# epidbot_volume_size      = 20   # GB - Chat history + pysus + plots (default: 20)
# backup_volume_size       = 100  # GB - Backup storage (default: 100)
# monitoring_volume_size   = 10   # GB - Prometheus/Grafana data (default: 10)

# STORAGE COST: 0.05 EUR/GB/month

# ============================================
# Domain Configuration
# ============================================

domain_name       = "kwar-ai.com.br"
epidbot_subdomain = "epidbot.kwar-ai.com.br"
libby_subdomain   = "libby.kwar-ai.com.br"
grafana_subdomain = "grafana.kwar-ai.com.br"

# ============================================
# SSH Configuration
# ============================================

# Option 1: Provide your existing SSH public key
# ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2E... your-email@example.com"

# Option 2: Leave empty to generate a new key pair (keys will be saved to ./ssh_keys/)
ssh_public_key = ""

ssh_key_name = "kwar-ai-ssh-key"

# ============================================
# Admin Configuration
# ============================================

admin_email = "admin@kwar-ai.com.br"

# ============================================
# Database Configuration
# ============================================

postgres_db       = "libby"
postgres_user     = "libby"
postgres_password = "CHANGE_ME_GENERATE_A_SECURE_PASSWORD_HERE"

# Generate a secure password:
# openssl rand -base64 32

# ============================================
# Application Secrets
# ============================================

# Generate a secure secret key for sessions
secret_key = "CHANGE_ME_GENERATE_A_RANDOM_SECRET_KEY"

# Generate with: openssl rand -hex 32

# ============================================
# API Keys (Leave empty if not used)
# ============================================

openai_api_key   = "sk-your-openai-api-key-here"
gemini_api_key   = "your-gemini-api-key-here"
zhipu_api_key    = "your-zhipu-api-key-here"
deepseek_api_key = "your-deepseek-api-key-here"

# ============================================
# OAuth Configuration (Optional)
# ============================================

github_client_id     = "your-github-client-id"
github_client_secret = "your-github-client-secret"

# ============================================
# Backup Configuration
# ============================================

backup_retention_days = 7

# ============================================
# Monitoring Configuration
# ============================================

enable_monitoring      = true
grafana_admin_password = "CHANGE_ME_GRAFANA_ADMIN_PASSWORD"

# ============================================
# LLM Configuration
# ============================================

embedding_model = "mxbai-embed-large"
ollama_model    = "llama3"

# ============================================
# Server Settings
# ============================================

timezone = "America/Sao_Paulo"
