services:
  epidbot:
    build: https://{{ github_token }}@github.com/DeepLearn-Ped/EpiDBot.git#main
    image: epidbot:latest
    container_name: epidbot
    ports:
      - '7860:7860'
    volumes:
      - epidbot_data:/data
      - ./data/pysus:/data/pysus
      - ./data/plots:/data/plots
    env_file:
      - .env
    environment:
      - OPENAI_API_KEY=${OPENAI_API_KEY}
      - ZHIPU_API_KEY=${ZHIPU_API_KEY}
      - DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
      - GOOGLE_API_KEY=${GOOGLE_API_KEY}
      - LIBBY_URL=http://libby-api:8000
      - OLLAMA_HOST=http://libby-ollama:11434
      - PYSUS_PATH=/data/pysus
      - PLOT_DIR=/data/plots
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '2'
          memory: 4G
        reservations:
          cpus: '1'
          memory: 2G
    networks:
      - kwar-ai-network
    healthcheck:
      test:
        - CMD
        - curl
        - -f
        - http://localhost:7860/
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 120s

volumes:
  epidbot_data:
    driver: local

networks:
  kwar-ai-network:
    external: true
